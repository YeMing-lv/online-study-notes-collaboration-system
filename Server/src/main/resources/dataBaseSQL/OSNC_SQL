CREATE TABLE `user` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '用户ID',
  `username` varchar(50) NOT NULL COMMENT '登录用户名',
  `password` varchar(100) NOT NULL COMMENT '加密密码',
  `name` varchar(50) NOT NULL DEFAULT '用户名' COMMENT '用户昵称',
  `email` varchar(100) DEFAULT NULL COMMENT '用户邮箱',
  `avatar` varchar(512) DEFAULT NULL COMMENT '头像URL',
  `status` tinyint NOT NULL DEFAULT '1' COMMENT '0-禁用，1-正常',
  `create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `update_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_username` (`username`),
  UNIQUE KEY `uk_email` (`email`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='系统用户表';

CREATE TABLE `note` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '笔记ID',
  `title` varchar(255) NOT NULL COMMENT '笔记标题',
  `content` longtext DEFAULT NULL COMMENT '笔记内容（富文本）',
  `user_id` bigint NOT NULL COMMENT '创建人ID',
  `folder_id` bigint DEFAULT NULL COMMENT '所属文件夹ID',
  `category_id` bigint DEFAULT NULL COMMENT '所属分类ID',
  `cover_url` varchar(512) DEFAULT NULL COMMENT '封面图URL',
  `is_public` tinyint NOT NULL DEFAULT '0' COMMENT '0-私有，1-公开',
  `read_count` int NOT NULL DEFAULT '0' COMMENT '阅读次数',
  `is_recycle` tinyint NOT NULL DEFAULT '0' COMMENT '是否在回收站',
  `delete_time` datetime DEFAULT NULL COMMENT '移入回收站时间',
  `recycle_expire_time` datetime DEFAULT NULL COMMENT '回收站过期时间',
  `is_deleted` tinyint NOT NULL DEFAULT '0' COMMENT '逻辑删除标记',
  `create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `update_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`),
  KEY `idx_user_category` (`user_id`, `category_id`),  -- 查用户某分类下的笔记
  KEY `idx_recycle` (`is_recycle`, `recycle_expire_time`),  -- 回收站清理
  KEY `idx_is_public` (`is_public`)  -- 查公开笔记
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='学习笔记核心表';

CREATE TABLE `note_category` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '分类ID',
  `user_id` bigint NOT NULL COMMENT '所属用户ID',
  `name` varchar(50) NOT NULL COMMENT '分类名称',
  `sort` int NOT NULL DEFAULT '0' COMMENT '排序值',
  `parent_id` bigint NOT NULL DEFAULT '0' COMMENT '父分类ID（0=顶级）',
  `is_deleted` tinyint NOT NULL DEFAULT '0' COMMENT '逻辑删除标记',
  `create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `update_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_user_parent_name` (`user_id`, `parent_id`, `name`),
  KEY `idx_user_parent` (`user_id`, `parent_id`)  -- 查用户的分类树
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='笔记分类表';

CREATE TABLE `note_version` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '版本ID',
  `note_id` bigint NOT NULL COMMENT '关联笔记ID',
  `content` longtext DEFAULT NULL COMMENT '版本内容',
  `version_num` int NOT NULL COMMENT '版本号',
  `edit_remark` varchar(255) DEFAULT NULL COMMENT '编辑备注',
  `user_id` bigint NOT NULL COMMENT '编辑人ID',
  `create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  PRIMARY KEY (`id`),
  KEY `idx_note_version` (`note_id`, `version_num`)  -- 查笔记的版本历史
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='笔记版本表（回溯编辑历史）';

CREATE TABLE `note_tag` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '标签ID',
  `user_id` bigint NOT NULL COMMENT '所属用户ID',
  `name` varchar(50) NOT NULL COMMENT '标签名称（如“面试重点”）',
  `color` varchar(20) DEFAULT '#333333' COMMENT '标签颜色（Hex）',
  `is_deleted` tinyint NOT NULL DEFAULT '0' COMMENT '逻辑删除标记',
  `create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_user_tag` (`user_id`, `name`)  -- 同一用户标签名唯一
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='笔记标签主表';

CREATE TABLE `note_tag_relation` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '关联ID',
  `note_id` bigint NOT NULL COMMENT '笔记ID',
  `tag_id` bigint NOT NULL COMMENT '标签ID',
  `create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_note_tag` (`note_id`, `tag_id`)  -- 一笔记一标签仅关联一次
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='笔记-标签关联表';

CREATE TABLE `learning_progress` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '进度ID',
  `user_id` bigint NOT NULL COMMENT '用户ID',
  `target_type` tinyint NOT NULL COMMENT '目标类型：1-笔记，2-文件',
  `target_id` bigint NOT NULL COMMENT '目标ID（笔记ID/文件ID）',
  `progress` varchar(100) DEFAULT NULL COMMENT '进度值（如“10页”“30%”“第5段”）',
  `progress_num` decimal(5,2) DEFAULT 0.00 COMMENT '进度数值（如30.00=30%）',
  `update_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_user_target` (`user_id`, `target_type`, `target_id`)  -- 同一用户同一目标仅一条进度
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='学习进度表';

CREATE TABLE `folder` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '文件夹ID',
  `user_id` bigint NOT NULL COMMENT '所属用户ID',
  `name` varchar(100) NOT NULL COMMENT '文件夹名称',
  `parent_id` bigint NOT NULL DEFAULT '0' COMMENT '父文件夹ID（0=根目录）',
  `sort` int NOT NULL DEFAULT '0' COMMENT '排序值',
  `is_recycle` tinyint NOT NULL DEFAULT '0' COMMENT '是否在回收站',
  `delete_time` datetime DEFAULT NULL COMMENT '移入回收站时间',
  `recycle_expire_time` datetime DEFAULT NULL COMMENT '回收站过期时间',
  `is_deleted` tinyint NOT NULL DEFAULT '0' COMMENT '逻辑删除标记',
  `create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `update_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`),
  KEY `idx_user_parent` (`user_id`, `parent_id`)  -- 查用户的文件夹树
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='文件夹表（管理笔记/文件）';

CREATE TABLE `file` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '文件ID',
  `folder_id` bigint DEFAULT NULL COMMENT '所属文件夹ID',
  `file_name` varchar(255) NOT NULL COMMENT '文件名',
  `file_path` varchar(512) NOT NULL COMMENT '文件存储路径',
  `file_size` bigint NOT NULL DEFAULT '0' COMMENT '文件大小（字节）',
  `file_type` varchar(50) DEFAULT '' COMMENT '文件类型',
  `upload_user_id` bigint NOT NULL COMMENT '上传人ID',
  `upload_time` datetime NOT NULL COMMENT '上传时间',
  `note_id` bigint DEFAULT NULL COMMENT '关联笔记ID（附件所属笔记）',
  `is_recycle` tinyint NOT NULL DEFAULT '0' COMMENT '是否在回收站：0-否，1-是',
  `delete_time` datetime DEFAULT NULL COMMENT '移入回收站时间',
  `delete_user_id` bigint DEFAULT NULL COMMENT '删除操作人ID',
  `recycle_expire_time` datetime DEFAULT NULL COMMENT '回收站过期时间',
  `is_deleted` tinyint NOT NULL DEFAULT '0' COMMENT '逻辑删除标记：0-未删，1-彻底删除',
  `create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `update_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`),
  -- 索引优化：提升查询/清理效率
  KEY `idx_upload_user_id` (`upload_user_id`),       -- 查用户所有文件
  KEY `idx_note_id` (`note_id`),                    -- 查询笔记所有附件
  KEY `idx_recycle_expire` (`is_recycle`,`recycle_expire_time`), -- 回收站清理
  KEY `idx_is_deleted` (`is_deleted`),                -- 过滤彻底删除的文件
  KEY `idx_upload_time` (`upload_user_id`, `upload_time` DESC),     -- 查用户自己的最新文件
  KEY `idx_update_time` (`upload_user_id`, `update_time` DESC)      -- 按更新时间（如编辑后）排序的最新文件
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='文件表（含回收站功能）';

-- 创建通用分享表
CREATE TABLE `share` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '分享记录ID',
  `target_type` tinyint NOT NULL COMMENT '分享目标类型：1-文件，2-笔记',
  `target_id` bigint NOT NULL COMMENT '目标ID（文件ID/笔记ID）',
  `share_from_user_id` bigint NOT NULL COMMENT '分享人ID',
  `share_to_user_id` bigint NOT NULL COMMENT '被分享人ID',
  `share_permission` tinyint NOT NULL DEFAULT '1' COMMENT '1-只读，2-可编辑，3-可下载，4-可分享',
  `share_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '分享时间',
  `share_expire_time` datetime DEFAULT NULL COMMENT '分享有效期（NULL=永久）',
  `is_share_valid` tinyint NOT NULL DEFAULT '1' COMMENT '0-失效，1-有效',
  `create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `update_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`),
  -- 核心索引：适配文件/笔记的分享查询
  KEY `idx_share_to_user` (`share_to_user_id`, `is_share_valid`, `target_type`),  -- 查用户接收的某类资源分享
  KEY `idx_share_from_target` (`target_type`, `target_id`, `share_from_user_id`), -- 查某资源的所有分享
  KEY `idx_share_expire` (`is_share_valid`, `share_expire_time`, `target_type`)   -- 清理过期分享
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='通用分享表（文件/笔记）';

-- 创建通用星标表
CREATE TABLE `star` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '星标记录ID',
  `target_type` tinyint NOT NULL COMMENT '星标目标类型：1-文件，2-笔记',
  `target_id` bigint NOT NULL COMMENT '目标ID（文件ID/笔记ID）',
  `user_id` bigint NOT NULL COMMENT '加星用户ID',
  `star_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '加星时间',
  `star_remark` varchar(255) DEFAULT NULL COMMENT '星标备注（如“项目核心文档”）',
  `is_canceled` tinyint NOT NULL DEFAULT '0' COMMENT '0-有效，1-取消',
  `create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `update_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`),
  -- 唯一索引：防止同一用户重复给同一资源加星
  UNIQUE KEY `uk_user_target` (`user_id`, `target_type`, `target_id`, `is_canceled`),
  -- 核心索引：适配文件/笔记的星标查询
  KEY `idx_star_user` (`user_id`, `is_canceled`, `target_type`, `star_time` DESC)  -- 查用户某类资源的加星记录
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='通用星标表（文件/笔记）';



